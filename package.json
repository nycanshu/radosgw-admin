{
  "name": "radosgw-admin",
  "version": "0.1.0",
  "description": "Node.js SDK for the Ceph RADOS Gateway Admin Ops API — manage users, buckets, quotas and rate limits programmatically",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:api": "typedoc",
    "docs:dev": "cd website && npm run start",
    "docs:build": "npm run docs:api && cd website && npm run build",
    "docs:serve": "cd website && npm run serve",
    "prepublishOnly": "npm run build && npm test",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nycanshu/radosgw-admin.git"
  },
  "keywords": [
    "ceph",
    "radosgw",
    "rados",
    "rgw",
    "s3",
    "object-storage",
    "admin",
    "ceph-admin",
    "rgw-admin",
    "rook-ceph",
    "rook",
    "openshift-data-foundation",
    "bucket-management",
    "user-management",
    "quota",
    "ceph-object-storage",
    "aws-sigv4",
    "storage-admin",
    "kubernetes-storage",
    "typescript"
  ],
  "author": "nycanshu <hkg43700@gmail.com> (https://github.com/nycanshu)",
  "homepage": "https://github.com/nycanshu/radosgw-admin#readme",
  "bugs": {
    "url": "https://github.com/nycanshu/radosgw-admin/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.19.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
